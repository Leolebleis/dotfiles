#!/bin/bash
# chezmoi modify script (templated) for ~/.claude/settings.json
# Ensures statusLine + zellij-attention notification hooks are configured.
# Idempotent: won't duplicate or overwrite existing entries.
set -euo pipefail

input="$(cat)"
[ -z "$input" ] && input='{}'

# No jq -> leave the file untouched (e.g. minimal Windows env without jq).
if ! command -v jq >/dev/null 2>&1; then
    echo "$input"
    exit 0
fi

# zellij-attention: append ⏳/✅ to the tab name when Claude needs input / finishes.
# Delegates to a pwsh wrapper script (resolved to an OS-native absolute path by
# chezmoi, because `pwsh -File` does NOT expand ~). The wrapper reads
# $ZELLIJ_PANE_ID natively, closes stdin so `zellij pipe` can't block, and caps
# the wait at 2s -- so the hook can never hang Claude Code. One pwsh command
# works across Windows/macOS/Linux (default shell is pwsh on all).
NOTIFY_SCRIPT='{{ .chezmoi.homeDir | replace "\\" "/" }}/.config/zellij/plugins/zellij-attention-notify.ps1'
attn_cmd() { printf 'pwsh -NoProfile -File "%s" %s' "$NOTIFY_SCRIPT" "$1"; }

output="$input"

# statusLine (add only if unset)
if ! echo "$output" | jq -e '.statusLine' >/dev/null 2>&1; then
    output="$(echo "$output" | jq '.statusLine = {"type": "command", "command": "bunx -y ccstatusline@latest", "padding": 0}')"
fi

# Notification -> waiting (add only if the Notification array has no attention hook)
if [ "$(echo "$output" | jq '[.hooks.Notification // [] | .[].hooks[]?.command // empty] | map(select(test("zellij-attention-notify"))) | length')" = "0" ]; then
    output="$(echo "$output" | jq --arg c "$(attn_cmd waiting)" \
        '.hooks.Notification += [{"hooks": [{"type": "command", "command": $c}]}]')"
fi

# Stop -> completed (add only if the Stop array has no attention hook)
if [ "$(echo "$output" | jq '[.hooks.Stop // [] | .[].hooks[]?.command // empty] | map(select(test("zellij-attention-notify"))) | length')" = "0" ]; then
    output="$(echo "$output" | jq --arg c "$(attn_cmd completed)" \
        '.hooks.Stop += [{"hooks": [{"type": "command", "command": $c}]}]')"
fi

echo "$output"
