#!/bin/bash
# chezmoi modify script for ~/.claude/settings.json
# Ensures statusLine is configured. Won't overwrite if already set.
set -euo pipefail

input="$(cat)"

if [ -z "$input" ]; then
    input='{}'
fi

if command -v jq >/dev/null 2>&1; then
    if echo "$input" | jq -e '.statusLine' >/dev/null 2>&1; then
        echo "$input"
    else
        echo "$input" | jq '.statusLine = {"type": "command", "command": "bunx -y ccstatusline@latest", "padding": 0}'
    fi
else
    echo "$input"
fi
