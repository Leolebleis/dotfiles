layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    tab name="dev" focus=true {
        pane split_direction="vertical" {
            pane name="claude" size="50%"
            pane name="dev" command="ssh" {
                args "dev"
            }
        }
    }

    tab name="minecraft" {
        pane split_direction="vertical" {
            pane name="mc-ssh" command="ssh" {
                args "minecraft"
            }
            pane name="dev-ssh" command="ssh" {
                args "dev"
            }
        }
    }

    tab name="cs" {
        pane name="cs-ssh" command="ssh" {
            args "cs"
        }
    }
}
