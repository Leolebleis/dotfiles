{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
# Pre-grant Zellij plugin permissions so users don't get confusing prompts.
# Zellij keys entries by resolved plugin location: local plugins use the
# expanded file path, URL plugins use the URL. Windows twin: the .ps1 script.
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
PERM_DIR="$HOME/Library/Caches/org.Zellij-Contributors.Zellij"
{{ else -}}
PERM_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zellij"
{{ end -}}

mkdir -p "$PERM_DIR"
PERM_FILE="$PERM_DIR/permissions.kdl"

[ -f "$PERM_FILE" ] && exit 0

PLUGIN_DIR="$HOME/.config/zellij/plugins"

cat > "$PERM_FILE" << EOF
"$PLUGIN_DIR/zellij-attention.wasm" {
    ReadApplicationState
    ChangeApplicationState
    ReadCliPipes
    MessageAndLaunchOtherPlugins
}
"$PLUGIN_DIR/zellij-autolock.wasm" {
    ReadApplicationState
    ChangeApplicationState
}
"$PLUGIN_DIR/zj-quit.wasm" {
    ChangeApplicationState
}
"$PLUGIN_DIR/zellij_forgot.wasm" {
    ReadApplicationState
    ChangeApplicationState
}
"$PLUGIN_DIR/room.wasm" {
    ReadApplicationState
    ChangeApplicationState
}
"https://github.com/UrosNikolic/zellij-claude/releases/latest/download/zellij-claude.wasm" {
    ReadApplicationState
    ChangeApplicationState
    RunCommands
    ReadCliPipes
}
EOF

echo "Zellij plugin permissions pre-granted."
{{ end -}}
